      <geometry>
        <box size="0.3 0.15 0.1"/>
      </geometry>
    </collision>
  </link>
  <link name="imu_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.005"/>
      <mass value="0.05"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.01" radius="0.03"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.01" radius="0.03"/>
      </geometry>
    </collision>
  </link>
  <!-- Left front leg links -->
  <link name="LFH_link">
    <visual>
