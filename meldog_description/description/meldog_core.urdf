    <inertial>
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <mass value="8.0"/>
      <inertia ixx="0.03333333333333334" ixy="0.0" ixz="0.0" iyy="0.4333333333333334" iyz=".0" izz="0.4533333333333334"/>
    </inertial>
    <visual name="trunk_base_visual">
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.8 0.2 0.1"/>
      </geometry>
    </visual>
    <visual name="trunk_actuators_left_visual">
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.175 0.0"/>
