<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <joint name="LFT_joint" type="revolute">
        <parent link="trunk_link" />
        <child link="LFH_link" />
        <!-- ADD LEG PLACEMENT AS PARAMETERS-->
                <origin xyz="${T_x}
                        ${T_y}
                        ${T_z}" 
                    rpy="0 0 0" />
        <limit lower="${T_lower_limit/180.0*pi}" 
               upper="${T_upper_limit/180.0*pi}" 
               effort="${T_effort}" 
               velocity="${T_velocity}" />
        <dynamics friction="${T_friction}" damping="${T_damping}" />
        <axis xyz="1 0 0" />
    </joint>
    
</robot>