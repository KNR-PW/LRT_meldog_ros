<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:property name="trunk_base_length" value="0.8" />
<xacro:property name="trunk_base_width" value="0.2" />
<xacro:property name="trunk_base_height" value="0.1" />
<!-- visual and collision STL have wrong orientation and position
 (CAD model was broken at the time of export), its fixed here-->

    <xacro:link_macro 
        name="trunk_link" 
        is_foot="0"
        vis_name="${trunk_vis_stl_name}" 
        coll_name="${trunk_coll_stl_name}" 

        
        vis_rpy="${pi/2} 0.0 ${pi/2}"
        vis_xyz="0.019774 0.0 0.0"

        coll_rpy="${pi/2} 0.0 ${pi/2}"
        coll_xyz="0.019774 0.0 0.0"

        m="${trunk_mass}" 
        cm_x="${trunk_cm_x}" 
        cm_y="${trunk_cm_y}" 
        cm_z="${trunk_cm_z}"

        ixx="${trunk_ixx}" ixy="${trunk_ixy}" ixz="${trunk_ixz}" 
                                iyy="${trunk_iyy}" iyz="${trunk_iyz}" 
                                                        izz="${trunk_izz}"/>

</robot>



